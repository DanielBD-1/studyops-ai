NODE_ENV=development
PORT=3001

# Supabase — placeholders only; copy to .env (never commit .env)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Frontend origin for CORS allowlist
FRONTEND_URL=http://localhost:5173

# Internal document processing service
DOCUMENT_SERVICE_URL=http://localhost:3002

# Trello OAuth (optional until connect flow is enabled — placeholders only)
TRELLO_API_KEY=your_trello_api_key_here
# 32-byte random value, base64-encoded (generate locally; never commit real key)
TRELLO_TOKEN_ENCRYPTION_KEY=your_base64_32_byte_encryption_key_here
